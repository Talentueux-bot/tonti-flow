# Copiez ce fichier vers .env.local et renseignez vos clés Supabase.
# (Settings → API Keys dans le dashboard Supabase)
# IMPORTANT : utilisez la clé PUBLIQUE (sb_publishable_… / anon), jamais la clé secrète.

NEXT_PUBLIC_SUPABASE_URL=https://votre-projet.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx
